# Copy this file to terraform.tfvars and fill in the values

project_id     = "your-gcp-project-id"
region         = "europe-west4"
neon_org_id    = "org-xxx-yyy-12345678"
zitadel_org_id = "123456789012345678"
zitadel_domain = "my-instance.us1.zitadel.cloud"

# Update after first deploy with the Cloud Run URL
oidc_redirect_uris             = ["http://localhost:8080/auth/callback"]
oidc_post_logout_redirect_uris = ["http://localhost:8080"]
