# GCP
PROJECT_ID=
REGION=europe-west4
SERVICE=cassiopeia

# Local dev database
DATABASE_URL=postgresql+asyncpg://cassiopeia:local@localhost:5432/cassiopeia

# OIDC (leave empty to disable auth)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Session encryption key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change-me-in-production

# Base URL for OIDC callback (no trailing slash)
BASE_URL=http://localhost:8080
